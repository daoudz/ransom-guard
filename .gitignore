## .NET / C# .gitignore

# Build output
bin/
obj/
publish/

# Visual Studio user-specific files
*.user
*.suo
*.userosscache
*.sln.docview

# Visual Studio cache / options
.vs/
*.rsuser

# NuGet packages
*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Rider / JetBrains
.idea/
*.sln.iml

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
